{
  "name": "dih",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start -p 3005",
    "lint": "next lint",
    "docker:build": "docker build -t dih .",
    "docker:start": "docker run -d --restart unless-stopped -p 3005:3005 --name dih dih",
    "docker:stop": "docker stop dih && docker rm dih",
    "docker:restart": "npm run docker:stop && npm run docker:start",
    "docker:logs": "docker logs -f dih"
  },
  "dependencies": {
    "next": "15.3.7",
    "next-intl": "^4.5.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4.1.17",
    "typescript": "^5"
  }
}
